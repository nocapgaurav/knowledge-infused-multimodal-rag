      "paper_id": "09190753-7b1e-461b-babe-06c455474b2f",
      "section_id": "6c413094-b120-49cf-bf2f-28bdce425604",
      "order": 1,
      "text": "Designed computer vision inference pipelines using OpenCV and MediaPipe , achieving 85%+ accuracy in pose classification across 5+ exercise types.",
      "bounding_boxes": [
        {
          "page_number": 1,
          "x0": 33.627,
