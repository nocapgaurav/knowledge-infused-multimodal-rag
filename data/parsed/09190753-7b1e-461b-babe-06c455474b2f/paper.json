      "paper_id": "09190753-7b1e-461b-babe-06c455474b2f",
      "section_id": "6c413094-b120-49cf-bf2f-28bdce425604",
      "order": 0,
      "text": "Built a real-time web application with a Flask REST API backend, exposing endpoints for live pose analysis and repetition tracking via webcam streams processed at 15-20 FPS .",
      "bounding_boxes": [
        {
          "page_number": 1,
          "x0": 33.328,
